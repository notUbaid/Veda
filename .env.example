# Veda — Environment Variables
# Copy this file to .env and fill in your values

# Gemini AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (Firebase Console → Project Settings → Your apps → Web app)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_ID=your_firestore_database_id

# ──────────────────────────────────────────────────────────
# After filling in the above, run:
#   npm install
#   npm run seed     ← creates all 9 demo accounts + mock data
#   npm run dev      ← starts the app
# ──────────────────────────────────────────────────────────
