rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────
    function uid() { return request.auth.uid; }
    function authed() { return request.auth != null; }

    function profile() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }
    function hasProfile() {
      return authed() && exists(/databases/$(database)/documents/users/$(uid()));
    }
    function role() { return hasProfile() ? profile().role : ''; }
    function myStoreId() { return hasProfile() ? profile().storeId : ''; }

    function isAdmin()      { return role() == 'admin'; }
    function isManager()    { return role() == 'manager'; }
    function isPharmacist() { return role() == 'pharmacist'; }
    function isStaff()      { return isAdmin() || isManager() || isPharmacist(); }

    // Manager owns a store if they are its managerId
    function managesStore(storeId) {
      return isAdmin() || (
        isManager() &&
        exists(/databases/$(database)/documents/stores/$(storeId)) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.managerId == uid()
      );
    }

    // ── /users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Everyone can read their own profile.
      // Admin reads all. Manager/Pharmacist read any user — frontend filters.
      allow read:   if authed();
      allow create: if authed() && (isAdmin() || uid() == userId);
      allow update: if isAdmin() || uid() == userId;
      allow delete: if isAdmin();
    }

    // ── /stores ───────────────────────────────────────────────────────────
    match /stores/{storeId} {
      allow read:   if authed();
      allow create: if isAdmin();
      allow update: if isAdmin() || managesStore(storeId);
      allow delete: if isAdmin();
    }

    // ── /medicines ────────────────────────────────────────────────────────
    match /medicines/{medicineId} {
      // All authenticated users can read (frontend filters by storeId).
      allow read:   if authed();
      // Admin: any store. Manager: only their store. Pharmacist: read only.
      allow create: if isAdmin() || isManager();
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin() || isManager();
    }

    // ── /batches ──────────────────────────────────────────────────────────
    match /batches/{batchId} {
      allow read:   if authed();
      // Pharmacist can update (decrement quantity on dispense).
      // Manager can create / update / delete.
      allow create: if isAdmin() || isManager();
      allow update: if authed(); // pharmacist decrements qty
      allow delete: if isAdmin() || isManager();
    }

    // ── /dispense_logs ────────────────────────────────────────────────────
    match /dispense_logs/{logId} {
      allow read:   if authed();
      allow create: if authed(); // pharmacist creates
      // Logs are immutable — no update or delete
    }

    // ── /orders ───────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:   if authed();
      allow create: if authed(); // manager or admin
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();
    }

    // ── /notifications ────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read:   if authed();
      allow create: if authed();
      allow update: if authed(); // mark as read
      allow delete: if isAdmin() || isManager();
    }

    // ── /audit_logs ───────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isAdmin() || isManager();
      allow create: if authed();
      // Immutable — no update or delete
    }

    // ── /waste_records ────────────────────────────────────────────────────
    match /waste_records/{recordId} {
      allow read:   if authed();
      allow create: if authed();
      allow update: if isAdmin() || isManager();
      allow delete: if isAdmin();
    }
  }
}
